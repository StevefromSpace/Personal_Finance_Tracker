# --- SQLite & Database (Privacy) ---
# Prevents your personal spending data from being uploaded
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Go Backend ---
# Ignore compiled binaries
backend/finance-tracker
backend/*.exe
# Ignore the environment file (if you create one)
backend/.env

# --- Frontend (React/Vite) ---
# Ignore dependencies and build output
**/node_modules/
**/dist/
**/dist-ssr/
frontend/.env
frontend/.env.local

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Editor & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db